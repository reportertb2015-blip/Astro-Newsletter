---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Sobre o Receita Grátis',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget: Foco na Autoridade do Anderson Kochanski -->

  <Hero
    tagline="Sobre o Portal"
    image={{
      src: 'https://images.unsplash.com/photo-1490645935967-10de6ba17061?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Cozinha Saudável Receita Grátis',
    }}
  >
    <Fragment slot="title">
      Sua dose diária de saúde com a série <br />
      <span class="text-accent dark:text-white">Cura Natureza</span>
    </Fragment>

    <Fragment slot="subtitle">
      O <strong>Receita Grátis</strong>, liderado por <strong>Anderson Kochanski</strong>, é um portal dedicado a transformar a alimentação em medicina natural. Com foco em ingredientes puros e técnicas ancestrais, ajudamos milhares de leitores a encontrarem equilíbrio e vitalidade.
    </Fragment>
  </Hero>

  <!-- Stats Widget: Dados do Portal -->

  <Stats
    title="Nossa trajetória em números"
    stats={[
      { title: 'Receitas Ativas', amount: '15k' },
      { title: 'Anos de Experiência', amount: '15' },
      { title: 'Leitores Mensais', amount: '50k+' },
      { title: 'Séries Exclusivas', amount: '3' },
    ]}
  />

  <!-- Features3 Widget: Categorias de Conteúdo -->

  <Features3
    title="Nossos Pilares"
    subtitle="Exploramos o melhor que a natureza oferece para sua mesa e seu bem-estar."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Cura Natureza',
        description:
          'Dicas e remédios naturais baseados no poder das plantas e alimentos integrais.',
        icon: 'tabler:leaf',
      },
      {
        title: 'Receitas Diárias',
        description:
          'Pratos práticos, econômicos e saborosos para facilitar o seu dia a dia na cozinha.',
        icon: 'tabler:soup',
      },
      {
        title: 'Educação Alimentar',
        description:
          'Informações técnicas sobre nutrientes para que você entenda o que consome.',
        icon: 'tabler:book',
      },
    ]}
  />

  <!-- Steps2 Widget: Valores do Negócio -->

  <Steps2
    title="Nossos Valores"
    subtitle="Compromisso com a verdade e a saúde da sua família."
    items={[
      {
        title: 'Foco no Leitor',
        description:
          'Priorizamos receitas que utilizam ingredientes acessíveis e métodos que realmente funcionam.',
      },
      {
        title: 'Melhoria Contínua',
        description:
          'Estamos sempre otimizando nossa plataforma para oferecer a melhor experiência de leitura e navegação.',
      },
      {
        title: 'Transparência',
        description:
          'Conteúdo produzido com ética, respeito às tradições e embasamento em resultados reais.',
      },
    ]}
  />

  <!-- Features2 Widget: Localização e Contato -->

  <Features2
    title="Onde estamos"
    tagline="Conecte-se conosco"
    columns={1}
    items={[
      {
        title: 'Sede Administrativa',
        description: 'Telêmaco Borba, Paraná, Brasil',
      },
    ]}
  />

  <!-- Features2 Widget: Suporte ao Leitor -->

  <Features2
    title="Fale com a Equipe"
    tagline="Contato"
    columns={2}
    items={[
      {
        title: 'Dúvidas sobre Receitas',
        description:
          'Tem alguma dúvida sobre um ingrediente ou preparo? Nossa equipe está pronta para ajudar.',
        icon: 'tabler:messages',
      },
      {
        title: 'Parcerias e Anúncios',
        description:
          'Interessado em colaborar com o Receita Grátis ou anunciar em nosso portal?',
        icon: 'tabler:headset',
      },
    ]}
  />
</Layout>
